# Required everywhere
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB

# Telegram bot on Railway
BOT_TOKEN=123456:telegram-bot-token

# Official Catapult public API collector, read-only key only
CATAPULT_API_URL=https://public-api.catapult.trade/graphql
CATAPULT_API_KEY=your_read_only_api_key

# Official API collection speed
API_COLLECTOR_INTERVAL_SECONDS=10
API_COLLECTOR_LIMIT=100
API_COLLECTOR_PAGES_PER_CYCLE=3
API_COLLECTOR_PAGE_SLEEP_SECONDS=0.2
API_COLLECTOR_SORT_FIELD=StartTime
API_COLLECTOR_SORT_DIRECTION=Desc
API_COLLECTOR_SPEED_MODE=

# Browser finished collector, local Windows only
HEADLESS=false
LOCAL_PROFILE_DIR=browser_profile_fast2
START_URL=https://catapult.trade/turbo/discover
FAST_FINISHED_USE_OFFICIAL_READY_QUEUE=true
FAST_FINISHED_ALLOW_SNAPSHOT_FALLBACK=false
FAST_FINISHED_READY_DELAY_SECONDS=90
FAST_FINISHED_INTERVAL_SECONDS=0.30
FAST_FINISHED_BATCH_LIMIT=200
NOT_READY_COOLDOWN_MINUTES=30
NOT_READY_MAX_RETRIES=8

# Analysis knobs
SWEEP_MIN_TRADES=10
SWEEP_FEE_PCT=0

# Live feature/signal knobs, later stage
LIVE_FEATURES_MIN_SNAPSHOTS=2
LIVE_FEATURES_LOOKBACK_MINUTES=30
LIVE_SIGNALS_MIN_TRADES=20
LIVE_SIGNALS_MIN_WINRATE=0.50
LIVE_SIGNALS_MIN_EXPECTANCY=5
LIVE_SIGNALS_MAX_AGE_SECONDS=300
