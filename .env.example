# Required everywhere
DATABASE_URL=

# Telegram
BOT_TOKEN=123456:telegram-bot-token
TELEGRAM_SIGNAL_CHAT_ID=-5247533913

# Railway process switches
RUN_OFFICIAL_COLLECTOR=true
RUN_LIVE_LOOP=true
RUN_SIGNAL_BROADCASTER=true
RUN_TELEGRAM_BOT=true
BOT_ONLY=false

# Official Catapult public API collector
CATAPULT_API_URL=https://public-api.catapult.trade/graphql
CATAPULT_API_KEY=

# Fast official API collection
API_COLLECTOR_INTERVAL_SECONDS=2
API_COLLECTOR_PAGES_PER_CYCLE=3
API_COLLECTOR_LIMIT=100
API_COLLECTOR_PAGE_SLEEP_SECONDS=0
API_COLLECTOR_SAVE_RAW=false

# Live loop
LIVE_LOOP_INTERVAL_SECONDS=5

# Live features
LIVE_FEATURES_MIN_SNAPSHOTS=2
LIVE_FEATURES_LOOKBACK_MINUTES=10
LIVE_FEATURES_STALE_SECONDS=60

# Live signals
LIVE_SIGNALS_MIN_TRADES=50
LIVE_SIGNALS_MIN_WINRATE=0.55
LIVE_SIGNALS_MIN_EXPECTANCY=5
LIVE_SIGNALS_MAX_AGE_SECONDS=900
LIVE_SIGNALS_MIN_SNAPSHOTS=3
LIVE_SIGNALS_STALE_SECONDS=60
LIVE_SIGNALS_MIN_PUMP_FOR_REVERSAL_PCT=40
LIVE_SIGNALS_MIN_REVERSAL_FROM_PEAK_PCT=10
LIVE_SIGNALS_MIN_CONFIDENCE=65
LIVE_SIGNALS_ALLOW_NO_REVERSAL_FOR_CRACK=false
LIVE_SIGNALS_MIN_MEDIAN_PNL=5
LIVE_SIGNALS_MAX_WORST_PNL=-70
LIVE_SIGNALS_MAX_STOP_DISTANCE_PCT=120
LIVE_SIGNALS_MIN_REWARD_RISK=0.35
LIVE_SIGNALS_SHORT_MIN_CURRENT_RETURN_PCT=5
LIVE_SIGNALS_MAX_STRATEGIES_PER_TOKEN_SIDE=5
LIVE_SIGNALS_DEBUG_LOG_LIMIT_PER_STATUS=5
LIVE_SIGNALS_OPEN_PAPER_IN_GENERATOR=false
LIVE_SIGNALS_CAP_EXECUTION_STOP=true
LIVE_SIGNALS_LONG_MIN_TRADES=50
LIVE_SIGNALS_LONG_MIN_WINRATE=0.55
LIVE_SIGNALS_LONG_MIN_EXPECTANCY=5
LIVE_SIGNALS_LONG_MIN_CONFIDENCE=65

# Signal paper trade config
LIVE_SIGNAL_SHORT_TP_PCT=12
LIVE_SIGNAL_SHORT_SL_PCT=18
LIVE_SIGNAL_LONG_TP_PCT=12
LIVE_SIGNAL_LONG_SL_PCT=18
PAPER_START_BALANCE_USDT=1000
PAPER_TRADE_SIZE_USDT=100
PAPER_AUTO_OPEN=true
PAPER_MAX_OPEN_TRADES=10
PAPER_MAX_POSITION_PCT=10
PAPER_STALE_CLOSE_SECONDS=180
PAPER_MAX_HOLD_SECONDS=600
SIGNAL_BROADCASTER_INTERVAL_SECONDS=5
SIGNAL_BROADCASTER_MAX_SIGNAL_AGE_MINUTES=10
SIGNAL_BROADCASTER_MAX_SENDS_PER_CYCLE=3

# Adaptive live performance
LIVE_SIGNALS_ADAPTIVE_LIVE_ENABLED=true
LIVE_SIGNALS_ADAPTIVE_LOOKBACK_DAYS=30
LIVE_SIGNALS_ADAPTIVE_MIN_CLOSED_TRADES=5
LIVE_SIGNALS_ADAPTIVE_DISABLE_WINRATE=0.35
LIVE_SIGNALS_ADAPTIVE_DISABLE_AVG_PNL=-15
LIVE_SIGNALS_ADAPTIVE_BOOST_WINRATE=0.60
LIVE_SIGNALS_ADAPTIVE_BOOST_AVG_PNL=5
LIVE_SIGNALS_ADAPTIVE_BOOST_CONFIDENCE=5

# Browser finished collector, local Windows only
HEADLESS=false
LOCAL_PROFILE_DIR=browser_profile_fast2
START_URL=https://catapult.trade/turbo/discover
FAST_FINISHED_USE_OFFICIAL_READY_QUEUE=true
FAST_FINISHED_ALLOW_SNAPSHOT_FALLBACK=false
FAST_FINISHED_READY_DELAY_SECONDS=90
FAST_FINISHED_INTERVAL_SECONDS=0.30
FAST_FINISHED_BATCH_LIMIT=200
NOT_READY_COOLDOWN_MINUTES=30
NOT_READY_MAX_RETRIES=8

# Analysis knobs
SWEEP_MIN_TRADES=10
SWEEP_FEE_PCT=0
